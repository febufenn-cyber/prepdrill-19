{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prepdrill.example/schemas/question.v1.schema.json",
  "title": "Prepdrill canonical question revision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question_id", "exam", "paper", "unit_id", "primary_concept_id",
    "secondary_concept_ids", "question_type", "content_language", "source_language",
    "plain_text", "stem_blocks", "options", "correct_option_id", "context_refs",
    "asset_ids", "difficulty", "provenance", "workflow_state", "issue_state",
    "validation_tier", "verification", "metadata"
  ],
  "properties": {
    "question_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{5,127}$"},
    "revision_id": {"type": "string"},
    "version": {"type": "integer", "minimum": 1},
    "exam": {"const": "ugc_net"},
    "paper": {"const": "paper_1"},
    "unit_id": {"type": "string", "minLength": 2},
    "topic_id": {"type": ["string", "null"]},
    "primary_concept_id": {"type": "string", "minLength": 2},
    "secondary_concept_ids": {"type": "array", "maxItems": 3, "uniqueItems": true, "items": {"type": "string", "minLength": 2}},
    "question_type": {"enum": ["single_choice", "assertion_reason", "match_following", "passage_linked", "table_based", "calculation", "multi_statement", "asset_dependent"]},
    "content_language": {"type": "string", "minLength": 2},
    "source_language": {"type": "string", "minLength": 2},
    "plain_text": {"type": "string", "minLength": 10},
    "stem_blocks": {"$ref": "#/$defs/blocks"},
    "options": {
      "type": "array", "minItems": 2, "maxItems": 8,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["option_id", "display_order", "plain_text", "blocks"],
        "properties": {
          "option_id": {"type": "string", "minLength": 1, "maxLength": 16},
          "display_order": {"type": "integer", "minimum": 0},
          "plain_text": {"type": "string", "minLength": 1},
          "blocks": {"$ref": "#/$defs/blocks"}
        }
      }
    },
    "correct_option_id": {"type": "string", "minLength": 1},
    "context_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "asset_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "difficulty": {"enum": ["unknown", "easy", "medium", "hard"]},
    "provenance": {
      "type": "object", "additionalProperties": true,
      "required": ["category", "source_title", "source_document_id", "source_locator", "rights_status", "answer_evidence"],
      "properties": {
        "category": {"enum": ["official_previous_year", "official_sample", "licensed_third_party", "internally_authored", "ai_assisted_reviewed", "ai_generated_experimental", "user_submitted"]},
        "source_title": {"type": "string", "minLength": 2},
        "source_document_id": {"type": "string", "minLength": 2},
        "source_locator": {"type": "string", "minLength": 1},
        "rights_status": {"enum": ["cleared", "official_publication_reviewed", "licensed", "owned", "unknown", "blocked"]},
        "answer_evidence": {"enum": ["official_key", "licensed_key", "independent_review", "author_review", "unverified"]},
        "answer_key_reference": {"type": ["string", "null"]}
      }
    },
    "workflow_state": {"enum": ["raw", "normalised", "review_pending", "approved", "published", "retired"]},
    "issue_state": {"enum": ["clear", "ambiguous", "disputed", "blocked"]},
    "validation_tier": {"enum": ["gold", "silver", "review", "blocked", "retired"]},
    "verification": {"type": "object", "additionalProperties": true},
    "metadata": {"type": "object"}
  },
  "$defs": {
    "blocks": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": true,
        "required": ["type"],
        "properties": {
          "type": {"enum": ["paragraph", "labelled_statement", "ordered_list", "unordered_list", "table", "formula", "image", "match_lists"]}
        }
      }
    }
  }
}
