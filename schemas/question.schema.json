{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prepdrill.example/schemas/question.schema.json",
  "title": "Prepdrill canonical question",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "question_id", "version", "exam", "paper", "unit_id", "primary_concept_id",
    "question_type", "question_text", "options", "correct_option_id",
    "provenance", "publication_state", "validation_tier"
  ],
  "properties": {
    "question_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{5,127}$"},
    "version": {"type": "integer", "minimum": 1},
    "exam": {"const": "ugc_net"},
    "paper": {"const": "paper_1"},
    "unit_id": {"type": "string", "minLength": 2},
    "topic_id": {"type": ["string", "null"]},
    "primary_concept_id": {"type": "string", "minLength": 2},
    "secondary_concept_ids": {"type": "array", "maxItems": 3, "uniqueItems": true, "items": {"type": "string", "minLength": 2}},
    "question_type": {"enum": ["single_choice", "assertion_reason", "match_following", "passage_linked", "table_based", "calculation", "multi_statement", "asset_dependent"]},
    "question_text": {"type": "string", "minLength": 10},
    "options": {
      "type": "array", "minItems": 2, "maxItems": 8,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["option_id", "text"],
        "properties": {
          "option_id": {"type": "string", "minLength": 1, "maxLength": 16},
          "text": {"type": "string", "minLength": 1}
        }
      }
    },
    "correct_option_id": {"type": "string", "minLength": 1},
    "year": {"type": ["integer", "null"], "minimum": 2000, "maximum": 2100},
    "exam_date": {"type": ["string", "null"], "format": "date"},
    "shift": {"type": ["string", "null"]},
    "source_question_number": {"type": ["string", "integer", "null"]},
    "passage_id": {"type": ["string", "null"]},
    "asset_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "difficulty": {"enum": ["unknown", "easy", "medium", "hard"]},
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["category", "source_title", "rights_status", "answer_evidence"],
      "properties": {
        "category": {"enum": ["official_previous_year", "official_sample", "licensed_third_party", "internally_authored", "ai_assisted_reviewed", "ai_generated_experimental", "user_submitted"]},
        "source_title": {"type": "string", "minLength": 2},
        "source_document_id": {"type": ["string", "null"]},
        "source_page": {"type": ["integer", "null"], "minimum": 1},
        "source_url": {"type": ["string", "null"]},
        "rights_status": {"enum": ["cleared", "official_publication_reviewed", "licensed", "owned", "unknown", "blocked"]},
        "answer_evidence": {"enum": ["official_key", "licensed_key", "independent_review", "author_review", "unverified"]},
        "answer_key_reference": {"type": ["string", "null"]}
      }
    },
    "publication_state": {"enum": ["imported", "auto_validated", "human_reviewed", "official_key_verified", "ambiguous", "disputed", "blocked", "published", "retired"]},
    "validation_tier": {"enum": ["gold", "silver", "review", "blocked", "retired"]},
    "explanation_status": {"enum": ["none", "draft", "canonical_reviewed", "blocked"]},
    "duplicate_group_id": {"type": ["string", "null"]},
    "metadata": {"type": "object"}
  }
}
